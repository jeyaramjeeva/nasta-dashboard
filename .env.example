# Free Supabase project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Shared password for the Upload Excel page (+ local login gate if no Supabase)
VITE_UPLOAD_PASSWORD="Nasta998#"

# Guest helper login (stall view only). Also create this user in Supabase Auth.
VITE_GUEST_PASSWORD="Guest9987"

# Team allowlist — only these emails can sign in (email:DisplayName)
# Create matching users in Supabase → Authentication → Users
# Always include guest@nastazentrum.de (Guest) — or the app adds Guest automatically
VITE_ALLOWED_EMAILS="jeeva@yourmail.com:Jeeva,sriram@yourmail.com:Sriram,sneha@yourmail.com:Sneha,guest@nastazentrum.de:Guest"

# Forgot-password requests are emailed to jeevajeyaraam@gmail.com (FormSubmit).
# First request may need one confirmation click in that inbox.
# Also add https://nastazentrum.vercel.app/account to Supabase Auth redirect URLs.
